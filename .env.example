# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/apidelta

# ──────────────────────────────────────────────
# Auth (NextAuth.js v5)
# ──────────────────────────────────────────────
# Base URL of the web app (used by NextAuth + Stripe redirects)
NEXTAUTH_URL=http://localhost:3000
# Random secret for JWT signing — generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# GitHub OAuth — create at https://github.com/settings/developers
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret

# Email magic links — sender address
EMAIL_FROM=APIDelta <noreply@apidelta.dev>
# Optional: full connection string (overrides SMTP_* vars below for auth emails)
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:465

# ──────────────────────────────────────────────
# Resend (used for alert emails — HTTP API, works on Railway)
# ──────────────────────────────────────────────
RESEND_API_KEY=re_xxx
# Optional: override sender (default: APIDelta <alerts@apidelta.dev>)
# RESEND_FROM=APIDelta <alerts@apidelta.dev>

# ──────────────────────────────────────────────
# Anthropic (AI classification)
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ──────────────────────────────────────────────
# Stripe (billing)
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs from Stripe Dashboard → Products
STRIPE_PRICE_ID_STARTER=price_xxx
STRIPE_PRICE_ID_PRO=price_xxx

# ──────────────────────────────────────────────
# Slack (alert transport)
# ──────────────────────────────────────────────
# Default webhook for testing — real webhooks are stored per alert rule in DB
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ──────────────────────────────────────────────
# Frontend → Backend
# ──────────────────────────────────────────────
# URL the Next.js frontend uses to reach the NestJS API
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ──────────────────────────────────────────────
# App config
# ──────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# ──────────────────────────────────────────────
# Google Analytics 4 (optional — omit to disable)
# Only emits events when NODE_ENV=production, so local dev won't pollute data
# ──────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
